{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(base64 *)",
      "Bash(cat *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(find *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rwx artifacts *)",
      "Bash(rwx logs *)",
      "Bash(rwx results *)",
      "Bash(rwx sandbox *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(which *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(find * -delete *)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}

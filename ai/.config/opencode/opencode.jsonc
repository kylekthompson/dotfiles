{
  "$schema": "https://opencode.ai/config.json",
  "theme": "gruvbox",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "default_agent": "plan",
  "permission": {
    "bash": {
      "*": "ask",

      "base64": "allow",
      "base64 *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "date": "allow",
      "date *": "allow",
      "dirname": "allow",
      "dirname *": "allow",
      "find": "allow",
      "find *": "allow",
      "gh api": "ask",
      "gh api *": "ask",
      "gh pr view": "allow",
      "gh pr view *": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",

      "git add": "allow",
      "git add *": "allow",
      "git commit": "allow",
      "git commit *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git grep": "allow",
      "git grep *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git merge-base": "allow",
      "git merge-base *": "allow",
      "git mv": "allow",
      "git mv *": "allow",
      "git rev-list": "allow",
      "git rev-list *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git show-ref": "allow",
      "git show-ref *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git push": "ask",
      "git push *": "ask",

      "grep": "allow",
      "grep *": "allow",
      "head": "allow",
      "head *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "mkdir": "allow",
      "mkdir *": "allow",
      "rwx artifacts": "allow",
      "rwx artifacts *": "allow",
      "rwx logs": "allow",
      "rwx logs *": "allow",
      "rwx results": "allow",
      "rwx results *": "allow",
      "rwx sandbox": "allow",
      "rwx sandbox *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "which": "allow",
      "which *": "allow",

      "find *-delete*": "deny",
      "find *-exec*": "deny",
      "find *-execdir*": "deny"
    }
  },
}

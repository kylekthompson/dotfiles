{
  "$schema": "https://opencode.ai/config.json",
  "theme": "gruvbox",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "default_agent": "plan",
  "permission": {
    "bash": {
      "*": "ask",

      "cat": "allow",
      "cat *": "allow",
      "find": "allow",
      "find *": "allow",

      "git add": "allow",
      "git add *": "allow",
      "git commit": "allow",
      "git commit *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git grep": "allow",
      "git grep *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git mv": "allow",
      "git mv *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git push": "ask",
      "git push *": "ask",

      "grep": "allow",
      "grep *": "allow",
      "head": "allow",
      "head *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "which": "allow",
      "which *": "allow",

      "find *-delete*": "deny",
      "find *-exec*": "deny",
      "find *-execdir*": "deny"
    }
  },
}
